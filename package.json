{
  "scripts": {
    "dev": "concurrently \"yarn start\" \"yarn start:api\"",
    "dev:live": "NC_DEV_LIVE=true yarn start",
    "dev:prod": "concurrently \"yarn start\" \"yarn start:api:prod\"",
    "prod:live": "cross-env NODE_ENV=production WEBPACK_SERVE=true webpack serve --mode=production --config webpack/webpack.config.prod.babel.mjs",
    "start": "cross-env START_HOT=1 NODE_ENV=development webpack serve --mode=development --config webpack/webpack.config.dev.babel.mjs --static-directory ./static --static-public-path /static",
    "lint": "eslint .",
    "prettier": "prettier --write .",
    "test": "LEAGUE_DB_HOST= LEAGUE_DB_PORT= TZ=America/New_York NODE_ENV=test TEST=all mocha --exit --exclude test/importer-espn.spec.mjs --exclude test/libs-server.get-players-table-view-results-debug.mjs --require test/setup-encryption-key.mjs --require test/global.mjs",
    "test:private": "LEAGUE_DB_HOST= LEAGUE_DB_PORT= TZ=America/New_York NODE_ENV=test TEST=all mocha --exit 'private/test/**/*.spec.mjs' --require test/setup-encryption-key.mjs --require test/global.mjs",
    "test:data-view-queries": "LEAGUE_DB_HOST= LEAGUE_DB_PORT= TZ=America/New_York NODE_ENV=test TEST=all mocha --exit test/libs-server.data-view-queries.mjs --require test/setup-encryption-key.mjs --require test/global.mjs",
    "test:db:up": "docker compose -f compose.test.yaml up -d --wait",
    "test:db:down": "docker compose -f compose.test.yaml down",
    "test:local": "yarn test:db:up && LEAGUE_DB_HOST=127.0.0.1 LEAGUE_DB_PORT=5433 TZ=America/New_York NODE_ENV=test TEST=all mocha --exit --exclude test/importer-espn.spec.mjs --exclude test/libs-server.get-players-table-view-results-debug.mjs --require test/setup-encryption-key.mjs --require test/global.mjs",
    "start:api": "NODE_ENV=development nodemon server.mjs",
    "start:api:prod": "NODE_ENV=production node server.mjs",
    "build": "cross-env NODE_ENV=production webpack --config ./webpack/webpack.config.prod.babel.mjs",
    "analyze": "cross-env OPEN_ANALYZER=true NODE_ENV=production webpack --config ./webpack/webpack.config.prod.babel.mjs",
    "deploy": "yarn load:main && yarn load:worker1",
    "deploy:dist": "rsync -av --delete --exclude 'stats.html' --exclude '*.map' dist/ league:/root/league/dist",
    "deploy:sourcemaps": "ssh league 'mkdir -p /root/league/sourcemaps' && rsync -av --delete --include='*.js.map' --exclude='*' dist/ league:/root/league/sourcemaps",
    "todo": "grep -rni todo app api common scripts",
    "count:lines": "git ls-files -- ':!:yarn.lock' ':!:./data' | xargs wc -l | tail -n 1",
    "load:main": "ssh -A league 'export NVM_DIR=\"$HOME/.nvm\" && [ -s \"$NVM_DIR/nvm.sh\" ] && . \"$NVM_DIR/nvm.sh\" && cd /root/league && git pull && git submodule update --init private && yarn install && pm2 reload server.pm2.config.js --env production'",
    "load:worker1": "ssh -A league-worker-1 'export NVM_DIR=\"$HOME/.nvm\" && [ -s \"$NVM_DIR/nvm.sh\" ] && . \"$NVM_DIR/nvm.sh\" && cd /root/league && git pull && git submodule update --init private && yarn install && pm2 reload import-live-odds-worker.pm2.config.js --env production && pm2 reload import-live-plays-worker.pm2.config.js --env production'",
    "load:crontab:main": "bash server/deploy-crontab.sh league server/crontab-main",
    "load:crontab:worker1": "bash server/deploy-crontab.sh league-worker-1 server/crontab-worker-1",
    "load:crontab:local": "cp -f private/crontab/crontab-local.cron $HOME/crontab/ && load_crontab_files",
    "load:logrotate:main": "ssh league 'cd /root/league && git pull && cp /root/league/server/logrotate-main /etc/logrotate.d/league-main'",
    "setup:node": "bash scripts/setup-node-version.sh",
    "export:schema": "ssh league 'pg_dump -U league_writer -h localhost --dbname=league_production --schema-only --clean --no-owner --if-exists --file=/root/schema.postgres.sql --no-tablespaces' && scp league:/root/schema.postgres.sql ./db/ && awk 'NR==17{print \"SET search_path = public;\"} !/^\\\\(un)?restrict /{print}' ./db/schema.postgres.sql > ./db/schema.tmp.sql && mv ./db/schema.tmp.sql ./db/schema.postgres.sql",
    "db:exec": "bash scripts/db-exec.sh",
    "generate:formats": "node scripts/generate-named-formats.mjs",
    "analyze:format-coverage": "node scripts/analyze-format-coverage.mjs",
    "generate:format-data": "node scripts/generate-format-data.mjs",
    "debug:data-view": "NODE_ENV=production node scripts/debug-data-view.mjs",
    "debug:plays-view": "NODE_ENV=production node scripts/debug-plays-view.mjs"
  },
  "imports": {
    "#config": "./config/index.mjs",
    "#db": "./db/index.mjs",
    "#db/*": "./db/*",
    "#api": "./api/index.mjs",
    "#api/*": "./api/*",
    "#test/*": "./test/*",
    "#libs-server": "./libs-server/index.mjs",
    "#libs-server/*": "./libs-server/*",
    "#libs-shared": "./libs-shared/index.mjs",
    "#libs-shared/*": "./libs-shared/*",
    "#constants": "./libs-shared/constants/index.mjs",
    "#constants/*": "./libs-shared/constants/*",
    "#scripts/*": "./scripts/*",
    "#jobs/*": "./jobs/*",
    "#league-import/*": "./league-import/*",
    "#private/libs-server": "./private/libs-server/index.mjs",
    "#private/*": "./private/*",
    "#app/*": "./app/*"
  },
