.nfl-week-filter
  display flex
  flex-direction column
  min-width 280px
  max-width 400px

.nfl-week-filter-section
  padding 8px
  border-bottom 1px solid $borderColor

  &:last-child
    border-bottom none

.nfl-week-filter-section-header
  font-size 0.625rem
  font-weight 700
  color lighten($textColor, 40%)
  text-transform uppercase
  letter-spacing 0.02em
  margin-bottom 6px

.nfl-week-builder-row
  display flex
  align-items center
  flex-wrap wrap
  gap 4px
  margin-bottom 6px

.nfl-week-builder-label
  font-size 0.6875rem
  font-weight 600
  color lighten($textColor, 20%)
  min-width 48px

.nfl-week-toggle-btn
  padding 2px 6px
  font-size 0.6875rem
  border-radius 3px
  cursor pointer
  user-select none
  background #f0f0f0
  border 1px solid #e0e0e0
  color $textColor
  min-width 28px
  text-align center
  line-height 1.4

  &:hover
    background darken(#f0f0f0, 10%)

  &.active
    background rgba(25, 118, 210, 0.12)
    border-color rgba(25, 118, 210, 0.4)
    color #1976d2

  &.dragging
    opacity 0.8

.nfl-week-builder-add
  display flex
  justify-content center
  padding 4px 0

  .controls-button
    background rgba(25, 118, 210, 0.08)
    border 1px solid rgba(25, 118, 210, 0.3)
    color #1976d2
    font-size 0.6875rem
    font-weight 600

    &:hover
      background rgba(25, 118, 210, 0.16)

    &.disabled
      opacity 0.4
      cursor default
      &:hover
        background rgba(25, 118, 210, 0.08)

.nfl-week-week-row
  display flex
  align-items center
  flex-wrap wrap
  gap 3px
  margin-bottom 4px

.nfl-week-week-row-label
  font-size 0.625rem
  color lighten($textColor, 30%)
  min-width 36px

.nfl-week-summary-group
  display flex
  align-items center
  justify-content space-between
  padding 3px 0
  font-size 0.6875rem

.nfl-week-summary-group-label
  flex 1
  color $textColor

.nfl-week-summary-group-remove
  font-size 0.625rem
  color lighten($textColor, 50%)
  cursor pointer
  padding 0 4px

  &:hover
    color #d32f2f

.nfl-week-summary-count
  font-size 0.625rem
  color lighten($textColor, 40%)
  padding 2px 0

.nfl-week-full-list
  max-height 200px
  overflow-y auto

.nfl-week-full-list-toggle
  font-size 0.625rem
  color #1976d2
  cursor pointer
  padding 4px 0

  &:hover
    text-decoration underline

.nfl-week-full-list-item
  display flex
  align-items center
  padding 2px 0
  cursor pointer
  font-size 0.6875rem

  &:hover
    background #fafafa

  .MuiCheckbox-root
    padding 0

  .MuiSvgIcon-root
    width 14px
    height 14px
