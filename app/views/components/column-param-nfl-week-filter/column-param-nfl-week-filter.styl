.nfl-week-filter
  display flex
  flex-direction column
  min-width 280px
  max-width 400px
  max-height calc(100vh - 200px)
  overflow-y auto

.nfl-week-filter-section
  padding 8px
  border-bottom 1px solid $borderColor

  &:last-child
    border-bottom none

.nfl-week-filter-section-header
  font-size 0.625rem
  font-weight 700
  color lighten($textColor, 40%)
  text-transform uppercase
  letter-spacing 0.02em
  margin-bottom 6px

.nfl-week-builder-hint
  font-size 0.5625rem
  color lighten($textColor, 50%)
  font-style italic
  margin-bottom 4px
  margin-top 4px

.nfl-week-builder-row
  display flex
  align-items center
  flex-wrap wrap
  gap 3px
  margin-bottom 8px

.nfl-week-builder-label
  font-size 0.625rem
  font-weight 600
  color lighten($textColor, 30%)
  text-transform uppercase
  letter-spacing 0.02em
  min-width 36px

.nfl-week-toggle-btn
  padding 2px 5px
  font-size 0.625rem
  border-radius 3px
  cursor pointer
  user-select none
  background #f5f5f5
  border 1px solid #e8e8e8
  color lighten($textColor, 10%)
  min-width 26px
  text-align center
  line-height 1.4

  &:hover
    background #e8e8e8
    border-color #d0d0d0

  &.active
    background rgba(25, 118, 210, 0.12)
    border-color rgba(25, 118, 210, 0.4)
    color #1976d2
    font-weight 600

.nfl-week-builder-add
  display flex
  flex-direction column
  align-items center
  padding 6px 0 2px
  gap 4px

  .controls-button
    background rgba(25, 118, 210, 0.08)
    border 1px solid rgba(25, 118, 210, 0.3)
    color #1976d2
    font-size 0.625rem
    font-weight 600

    &:hover
      background rgba(25, 118, 210, 0.16)

    &.disabled
      opacity 0.4
      cursor default
      &:hover
        background rgba(25, 118, 210, 0.08)

.nfl-week-builder-missing
  font-size 0.5625rem
  color lighten($textColor, 50%)
  font-style italic

.nfl-week-week-row
  display flex
  align-items center
  flex-wrap wrap
  gap 3px
  margin-bottom 4px

.nfl-week-week-row-label
  font-size 0.5625rem
  font-weight 600
  color lighten($textColor, 35%)
  text-transform uppercase
  letter-spacing 0.02em
  min-width 36px

.nfl-week-summary-group
  display flex
  align-items center
  justify-content space-between
  padding 3px 0
  font-size 0.6875rem

.nfl-week-summary-group-label
  flex 1
  color $textColor

.nfl-week-summary-group-remove
  font-size 0.625rem
  color lighten($textColor, 50%)
  cursor pointer
  padding 0 4px

  &:hover
    color #d32f2f

.nfl-week-summary-count
  font-size 0.625rem
  color lighten($textColor, 40%)
  padding 2px 0

.nfl-week-full-list
  max-height 200px
  overflow-y auto

.nfl-week-full-list-toggle
  font-size 0.625rem
  color #1976d2
  cursor pointer
  padding 4px 0

  &:hover
    text-decoration underline

.nfl-week-full-list-item
  display flex
  align-items center
  padding 2px 0
  cursor pointer
  font-size 0.6875rem

  &:hover
    background #fafafa

  .MuiCheckbox-root
    padding 0

  .MuiSvgIcon-root
    width 14px
    height 14px
