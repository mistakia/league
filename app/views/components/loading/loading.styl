.loading
  display flex
  align-items center
  justify-content center
  height 100%
  width 100%
  flex 1
  min-height 100px

.loading__spinner
  width 40px
  height 40px
  border 3px solid rgba(25, 118, 210, 0.2)
  border-top-color #1976d2
  border-radius 50%
  animation loading-spin 0.9s linear infinite

@keyframes loading-spin
  to
    transform rotate(360deg)
