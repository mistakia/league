$hoverBackground = rgba(255, 255, 255, 0.8)
$menuBackgroundColor = darken($backgroundColor, 5%)
$primaryColor = #1976d2
$primaryColorDark = #115293

.main__menu
  absolute left 0 right 0 top 0 bottom 0
  overflow-y scroll
  display flex
  flex-direction column

.menu__icon
  display inline-block
  fill currentColor
  vertical-align middle

.main__menu-button
  position fixed
  display inline-flex
  align-items center
  gap 8px
  height 48px
  padding 0 20px
  border none
  border-radius 24px
  background $primaryColor
  color #fff
  font-family inherit
  font-size 14px
  font-weight 500
  letter-spacing 0.02857em
  text-transform uppercase
  cursor pointer
  z-index 1100
  box-shadow 0 3px 5px -1px rgba(0,0,0,0.2), 0 6px 10px 0 rgba(0,0,0,0.14), 0 1px 18px 0 rgba(0,0,0,0.12)
  transition background-color 250ms cubic-bezier(0.4, 0, 0.2, 1), box-shadow 250ms cubic-bezier(0.4, 0, 0.2, 1)
  &:hover
    background $primaryColorDark
  &:focus-visible
    outline 2px solid $primaryColorDark
    outline-offset 2px

.menu__icon-button
  display inline-flex
  align-items center
  justify-content center
  width 24px
  height 24px
  padding 0
  margin 0 0 0 4px
  border none
  background transparent
  color inherit
  cursor pointer
  border-radius 50%
  &:hover
    background rgba(0, 0, 0, 0.04)

.menu__collapse-button
  display inline-flex
  align-items center
  justify-content center
  width 40px
  height 40px
  border none
  border-radius 50%
  background $primaryColor
  color #fff
  cursor pointer
  box-shadow 0 3px 5px -1px rgba(0,0,0,0.2), 0 6px 10px 0 rgba(0,0,0,0.14), 0 1px 18px 0 rgba(0,0,0,0.12)
  transition background-color 250ms cubic-bezier(0.4, 0, 0.2, 1)
  &:hover
    background $primaryColorDark

.league__menu
  display flex
  padding-left 32px
  position relative

.league__title
  font-family 'IBM Plex Mono'
  font-size 21px
  padding-bottom 8px
  display flex
  justify-content center
  padding 16px 8px

.menu__collapse
  position absolute
  right 4px
  bottom 16px

.menu__sections
  flex 1 0 auto
  display flex
  flex-wrap wrap
  align-content flex-start
  padding 14px
  font-family 'Inter', sans-serif

.menu__backdrop
  position fixed
  inset 0
  background rgba(0, 0, 0, 0.5)
  z-index 1200
  -webkit-tap-highlight-color transparent

.menu__drawer
  position fixed
  top 0
  bottom 0
  width $menuWidth
  background $menuBackgroundColor
  z-index 1300
  overflow hidden
  display flex
  flex-direction column
  transition transform 225ms cubic-bezier(0, 0, 0.2, 1)
  .menu__sections
    max-width 1100px
    margin 0 auto
    padding 16px 24px

.menu__drawer--persistent
  left 0
  transform translateX(-100%)
  &.menu__drawer--open
    transform translateX(0)

.menu__drawer--temporary
  transform translateX(100%)
  right 0
  &.menu__drawer--open
    transform translateX(0)

.menu__section
  border-radius 4px
  min-width 136px
  background lighten($menuBackgroundColor, 40%)
  flex 1
  margin 8px
  transition background-color $smooth_transition,box-shadow $smooth_transition,border $smooth_transition

.menu__links
  margin-top 8px
  padding-bottom 8px
  a
    display flex
    align-items center
    padding 3px 16px
    font-weight 400
    font-size 12px
    line-height 16px
    &.active
      font-weight 900
      color red

.menu__heading
  padding 16px 16px 0
  font-weight 600
  text-transform capitalize
  font-family 'IBM Plex Mono', monospace
  display flex
  align-items center
  .team__image
    margin 4px
    width 30px
    height 30px

.menu__text
  font-family 'Montserrat', sans-serif
  font-size 32px
  letter-spacing 0.1em
  margin 48px auto 32px
  transition color $smooth_transition,box-shadow $smooth_transition

.menu__open .main__menu-button
  display none

.league__warning
  display flex
  align-items center
  justify-content center
  background-color rgb(255, 244, 229)
  padding 6px
  font-size 10px

@media (min-width 800px)
  .menu__drawer--persistent
    border-right 1px solid lighten($borderColor, 30%)

  .auction__live .main__menu-button
    bottom $auctionHeightDesktop + 8px

@media (max-width 799px)
  .auction__live .main__menu-button
    bottom $auctionHeightMobile + 8px

@media (pointer: fine)
  .menu__links a:hover
  a.menu__text:hover
    color red
  .main__menu a:hover
    background-color rgba(0,0,0,0.08)
  .menu__section:hover
    border-color rgba(0, 0, 0, 0.23)
    background $hoverBackground
    box-shadow $box_shadow

@media (max-width 500px)
  .menu__links a
    font-size 14px
    line-height 18px
    min-height 36px

@media (pointer: coarse)
  .menu__links a
    font-size 14px
    line-height 18px
    min-height 36px
