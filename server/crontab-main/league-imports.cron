PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

JOB_PROJECT=league

## draft notifications
1 4 * * * NODE_ENV=production /root/.nvm/versions/node/current/bin/node /root/league/scripts/notifications-draft.mjs >> /var/log/league/notifications-draft.log 2>&1


